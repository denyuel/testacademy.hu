{
  "name": "testacademy.hu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx tailwindcss -i ./input.css -o ./output.css --minify",
    "dev": "npx tailwindcss -i ./input.css -o ./output.css --watch",
    "lint": "npm run lint:html",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "htmlhint \"**/*.html\""
  },
  "devDependencies": {
    "htmlhint": "^1.6.3",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19"
  }
}
