{
  "name": "testacademy.hu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx tailwindcss -i ./input.css -o ./output.css --minify && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});['index.html','output.css','thanks.html','_redirects','favicon.ico','og-image.png'].forEach(f=>{try{fs.copyFileSync(f,'dist/'+f)}catch(e){}})\"",
    "dev": "npx tailwindcss -i ./input.css -o ./output.css --watch",
    "lint": "npm run lint:html",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "htmlhint \"**/*.html\""
  },
  "devDependencies": {
    "htmlhint": "^1.6.3",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
